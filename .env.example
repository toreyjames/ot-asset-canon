# OT Asset Canon Environment Variables
# Copy this to .env.local and fill in values

# Anthropic API Key for Claude AI integration
ANTHROPIC_API_KEY=sk-ant-...

# Optional direct Postgres URL
# Format: postgresql://user:password@host/database?sslmode=require
DATABASE_URL=

# Supabase-backed server access for Baseload
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
CRON_SECRET=
INDUSTRIAL_TRACKER_INGEST_KEY=
INDUSTRIAL_TRACKER_SOURCES=usaspending,epa-frs,epa-echo,eia-electricity,eia-grid-monitor,interconnection-queue,ny-esd-incentives,texas-governor-projects,michigan-medc-projects,arizona-commerce-projects,ohio-jobs-projects,chips-awards,doe-edf-projects
INDUSTRIAL_TRACKER_INGEST_STATES=TX,IL
USASPENDING_LIMIT=100
USASPENDING_START_DATE=
USASPENDING_END_DATE=
EPA_FRS_LIMIT=150
EPA_ECHO_LIMIT=150
FRS_ZIP_URL=https://ordspub.epa.gov/ords/frs_public2/frs_rest_services.get_national_combined_file?p_output=ZIP
ECHO_ZIP_URL=https://echo.epa.gov/files/echodownloads/echo_exporter.zip
EIA_API_KEY=
EIA_ELECTRICITY_URL=
EIA_GRID_URL=
EIA_860_URL=https://www.eia.gov/electricity/data/eia860/xls/eia8602024.zip
INTERCONNECTION_QUEUE_URL=https://eta-publications.lbl.gov/sites/default/files/2025-08/lbnl_ix_queue_data_file_thru2024_v2.xlsx
INTERCONNECTION_QUEUE_LIMIT=500
INTERCONNECTION_QUEUE_MIN_MW=100
CBSA_DELINEATION_URL=https://www2.census.gov/programs-surveys/metro-micro/geographies/reference-files/2023/delineation-files/list1_2023.xlsx
CBSA_IMPORT_LIMIT=
SEC_TRACKER_CIKS=
SEC_FILING_LIMIT=25
SEC_USER_AGENT=Baseload Industrial Tracker contact@aibaseload.com
INDUSTRIAL_TRACKER_PROJECT_FEED=
CHIPS_AWARD_URLS=
CHIPS_AWARDS_USER_AGENT=Baseload Industrial Tracker contact@aibaseload.com
DOE_EDF_PROJECT_URLS=
DOE_EDF_USER_AGENT=Baseload Industrial Tracker contact@aibaseload.com
