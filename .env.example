# Vercel Blob Storage (auto-populated when you create Vercel Blob storage)
BLOB_READ_WRITE_TOKEN=

# Data boundary controls (default to metadata-only; hosted raw storage is pilot-only)
BASELINE_ALLOW_HOSTED_RAW_UPLOADS=false
BASELINE_ALLOW_HOSTED_INTAKE_STORAGE=false
