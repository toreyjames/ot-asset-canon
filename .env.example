MICHIGAN_PROJECT_URLS=
MICHIGAN_PROJECTS_USER_AGENT=Baseload Industrial Tracker contact@aibaseload.com
ARIZONA_PROJECT_URLS=
ARIZONA_PROJECTS_USER_AGENT=Baseload Industrial Tracker contact@aibaseload.com
OHIO_PROJECT_URLS=
GEORGIA_PROJECT_URLS=
NORTH_CAROLINA_PROJECT_URLS=
TENNESSEE_PROJECT_URLS=
SOUTH_CAROLINA_PROJECT_URLS=
